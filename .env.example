# Copy to .env and adjust. docker-compose reads this automatically.

# --- Django ---
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
DJANGO_DEBUG=False
# Hostnames THIS server answers to (its own address). Host only: NO http://, NO port.
# On a deployed box add its public IP/domain, e.g. ...,13.206.201.237
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Keep True only behind HTTPS. On plain http, set False or session/admin login breaks.
DJANGO_SECURE_COOKIES=True
# CSRF-trusted origins (scheme://host[:port]) — for the Django admin + browsable API.
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- CORS (browser ORIGINS allowed to call the API cross-origin) ---
# This is what lets a frontend on another origin (e.g. the admin console at
# http://localhost:5173) call the API. scheme + host + port, comma-separated.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Or open to all origins for quick dev (overrides the scoped list above):
CORS_ALLOW_ALL_ORIGINS=False

# --- Throttling (per-endpoint rate limits) ---
THROTTLE_ANON=60/min
THROTTLE_USER=1000/day
THROTTLE_LOGIN=5/min
THROTTLE_PASSWORD_RESET=3/min

# --- Postgres ---
POSTGRES_DB=education_os
POSTGRES_USER=education_os
POSTGRES_PASSWORD=education_os

# --- Auto-created admin user (dev convenience; disable in production) ---
DJANGO_CREATE_SUPERUSER=true
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin
